{
  "cli": {
    "version": ">= 5.2.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "web": {
        "env": {
          "NODE_ENV": "development"
        }
      }
    },
    "preview": {
      "distribution": "internal",
      "web": {
        "env": {
          "NODE_ENV": "preview"
        }
      }
    },
    "production": {
      "web": {
        "env": {
          "NODE_ENV": "production"
        }
      }
    }
  }
}
